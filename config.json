{
  "servers": [
    {
      "host": "127.0.0.1",
      "ports": [8080, 8081],
      "default": true,
      "client_max_header_size": 16384,
      "client_max_body_size": 10485760,
      "error_pages": {
        "400": "/error_pages/400.html",
        "403": "/error_pages/403.html",
        "404": "/error_pages/404.html",
        "405": "/error_pages/405.html",
        "413": "/error_pages/413.html",
        "500": "/error_pages/500.html"
      },
      "routes": [
        {
          "path": "/",
          "methods": ["GET", "POST", "DELETE"],
          "root": "./www",
          "index": "index.html"
        },
        {
          "path": "/upload",
          "methods": ["POST", "GET"],
          "root": "./www/uploads",
          "directory_listing": true
        },
        {
          "path": "/cgi-bin",
          "methods": ["GET", "POST"],
          "cgi_extension": ".py",
          "root": "./cgi-bin"
        },
        {
          "path": "/redirect",
          "redirect": "http://127.0.0.1:8080/",
          "redirect_code": 301
        }
      ]
    }
  ]
}
